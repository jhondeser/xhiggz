// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Nivel {
  Principiante
  Intermedio
  Avanzado
  TodosLosNiveles
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
}

enum EnrollmentSource {
  ONE_TIME      // pago único de un curso (Order)
  SUBSCRIPTION  // viene de una suscripción al catálogo
  MANUAL        // alta manual desde admin
}

enum EnrollmentStatus {
  ACTIVE
  EXPIRED
  REFUNDED
  CANCELED
}

model User {
  id         Int        @id @default(autoincrement())
  name       String
  email      String     @unique
  // Opcional: usuarios creados durante el checkout de Stripe pueden no tener
  // password todavía. Se setea al activar la cuenta vía email.
  password   String?
  role       Role       @default(STUDENT)

  // Stripe — un solo Customer por usuario
  stripeCustomerId String? @unique

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  enrollments         Enrollment[]
  coursesTaught       Course[]       @relation("InstructorCourses")
  testimonialsWritten Testimonial[]
  orders              Order[]
  subscriptions       Subscription[]
}

model Course {
  id          Int     @id @default(autoincrement())
  slug        String  @unique
  title       String
  description String
  emoji       String?
  modelKey    String?
  categoria   String
  img         String

  // Metadatos pedagógicos
  nivel       Nivel?
  duracion    String?
  rating      Float?
  estudiantes Int       @default(0)
  destacado   Boolean   @default(false)
  tags        String[]  @default([])

  // Precio (denormalizado: cada curso tiene exactamente un precio)
  precioMensual  Float?
  precioCompleto Float?
  precioMoneda   String? @default("EUR")

  // Stripe — cada curso tiene dos prices:
  //   - Monthly: subscription recurring mensual (Stripe mode='subscription')
  //   - Yearly:  pago one-time, da acceso por 1 año (Stripe mode='payment')
  // No guardamos productId porque, según el flujo actual, podría haber 2
  // productos por curso (uno por modalidad) y la decisión real se toma
  // a nivel de price, no de product.
  stripePriceIdMonthly String? @unique
  stripePriceIdYearly  String? @unique

  // Contenido (denormalizado)
  modulosCount   Int?
  horas          Int?
  proyectosCount Int?

  // Listas
  requisitos String[] @default([])
  objetivos  String[] @default([])
  beneficios String[] @default([])

  // Booleanos
  certificado     Boolean @default(false)
  accesoVitalicio Boolean @default(false)
  soporte         Boolean @default(false)
  comunidad       Boolean @default(false)

  // Estadísticas (denormalizado)
  satisfaccion  Float?
  empleabilidad Float?
  completacion  Float?

  // Calendario
  fechaInicio DateTime?
  fechaFin    DateTime?

  // Instructor — datos de display (no requieren un User registrado)
  instructorNombre      String?
  instructorAvatar      String?
  instructorRol         String?
  instructorExperiencia String?

  // Relación opcional a User (para futuro panel de instructores autenticados).
  // Hoy puede quedar en null y mostrarse con los campos instructor* anteriores.
  instructorId Int?
  instructor   User? @relation("InstructorCourses", fields: [instructorId], references: [id])

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relaciones
  temario       CourseModule[]
  enrollments   Enrollment[]
  testimonials  Testimonial[]
  orders        Order[]
  leads         Lead[]
  subscriptions Subscription[]

  @@index([categoria])
  @@index([destacado])
  @@index([nivel])
}

model CourseModule {
  id      Int      @id @default(autoincrement())
  modulo  String
  semanas String
  temas   String[] @default([])
  orden   Int      @default(0)

  courseId Int
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Enrollment {
  id         Int              @id @default(autoincrement())
  userId     Int
  courseId   Int

  source     EnrollmentSource @default(MANUAL)
  status     EnrollmentStatus @default(ACTIVE)

  // Procedencia opcional: una inscripción puede venir de un Order one-time
  // o de una Subscription al catálogo (o ser manual desde admin → ambos null)
  orderId        Int?
  order          Order?        @relation(fields: [orderId], references: [id])
  subscriptionId Int?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  enrolledAt DateTime  @default(now())
  // null = acceso vitalicio. Si viene de suscripción, se actualiza con
  // currentPeriodEnd en cada renovación.
  expiresAt  DateTime?

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([status])
  @@index([orderId])
  @@index([subscriptionId])
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  content   String
  rating    Int      @default(5)
  createdAt DateTime @default(now())

  authorId Int
  courseId Int

  author User   @relation(fields: [authorId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
}

// =============================================================================
// CRM + Pagos (Fase 2)
// =============================================================================

// Visitante que dejó email/teléfono pero aún no compró.
// Cuando paga, no lo borramos: lo enlazamos al User creado.
model Lead {
  id        Int      @id @default(autoincrement())
  email     String
  name      String?
  phone     String?
  // Origen libre: 'landing', 'curso-detalle', 'newsletter', etc.
  source    String?
  // Si dejó email en una página de curso concreto
  courseId  Int?
  course    Course?  @relation(fields: [courseId], references: [id])

  // UTM tracking
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  // Notas internas (desde el admin)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Una persona puede ser lead de varios cursos (un Lead distinto por curso),
  // pero NO se duplica un mismo email para el mismo curso. Reintentos del
  // checkout actualizan el Lead existente (vía upsert) en vez de crear filas.
  @@unique([email, courseId])
  @@index([email])
  @@index([courseId])
  @@index([createdAt])
}

// Pago único (one-time). Una Order genera 1 Enrollment del courseId comprado.
model Order {
  id Int @id @default(autoincrement())

  // Stripe IDs
  stripeSessionId       String  @unique
  stripePaymentIntentId String? @unique

  // Comprador
  userId        Int?
  user          User?  @relation(fields: [userId], references: [id])
  customerEmail String  // siempre lo capturamos, aunque User aún no exista

  // Producto comprado
  courseId Int?
  course   Course? @relation(fields: [courseId], references: [id])

  // Importes
  amount   Int    // en centavos (Stripe)
  currency String @default("eur")

  status   OrderStatus @default(PENDING)

  paidAt     DateTime?
  refundedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments Enrollment[]

  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@index([customerEmail])
}

// Suscripción mensual recurring a UN curso concreto. Genera 1 Enrollment con
// source=SUBSCRIPTION cuyo expiresAt se mantiene = currentPeriodEnd mientras
// la suscripción esté activa. Cuando se cancela/expira, el Enrollment pasa
// a EXPIRED y el usuario pierde acceso a ese curso.
model Subscription {
  id Int @id @default(autoincrement())

  // Stripe IDs
  stripeSubscriptionId String @unique
  stripePriceId        String
  stripeCustomerId     String

  userId   Int
  user     User   @relation(fields: [userId], references: [id])
  courseId Int
  course   Course @relation(fields: [courseId], references: [id])

  status SubscriptionStatus @default(INCOMPLETE)

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAt           DateTime?
  canceledAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments Enrollment[]

  @@index([userId])
  @@index([courseId])
  @@index([status])
}

// Idempotencia de webhooks: cada event.id de Stripe se guarda al procesarlo.
// Si llega un duplicado, se ignora.
model StripeEvent {
  id            Int      @id @default(autoincrement())
  stripeEventId String   @unique
  type          String
  payload       Json
  processedAt   DateTime @default(now())

  @@index([type])
}
